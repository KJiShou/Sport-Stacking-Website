rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {
        // Team membership is validated atomically by mutateAdminTeam. Client
        // writes would bypass the one-team-per-event invariant.
        match /teams/{document=**} {
            allow read: if true;
            allow write: if false;
        }

        // Preserve the application's current permissions for every other root
        // collection while making teams the only server-authoritative resource.
        match /{collection}/{document=**} {
            allow read, write: if collection != "teams";
        }
    }
}
